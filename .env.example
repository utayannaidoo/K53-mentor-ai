# ─────────────────────────────────────────────────────────────
# K53 Mentor AI — environment variables
#
# The app runs out-of-the-box in LOCAL DEMO MODE with no env set:
#   - content is seeded from src/lib/content/*
#   - progress persists to the browser (localStorage)
#   - the AI tutor falls back to a built-in rule-based explainer
#
# Set the variables below to switch to the production stack
# (Supabase persistence, real AI tutor, Stripe billing).
#
# ── PRODUCTION CHECKLIST (paid access is enforced server-side) ──
#  1. Supabase: set all three keys; run migrations 0001–0006.
#     Tier truth is the `subscriptions` table — only the Stripe
#     webhook writes it, so nothing works "paid" without a payment.
#  2. Stripe: secret key, webhook secret (endpoint /api/stripe/webhook,
#     events: checkout.session.completed, checkout.session.async_payment_succeeded,
#     customer.subscription.updated, customer.subscription.deleted),
#     and both monthly price IDs.
#  3. Upstash Redis: REQUIRED in production — per-user daily AI
#     allowances (3/15/40 tutor msgs by tier, vision paid-only) and
#     IP rate limits reset per instance without it on serverless.
#  4. CRON_SECRET: any long random string (Vercel sends it to the
#     notification cron automatically).
#  5. AI provider: set a spend cap in the provider dashboard.
#  6. NEXT_PUBLIC_SITE_URL: the real https origin (auth + Stripe redirects).
# ─────────────────────────────────────────────────────────────

# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── AI tutor provider ─────────────────────────────────────────
# The tutor auto-selects a provider: Anthropic (if its key is set) → OpenAI →
# built-in local fallback. Force one with TUTOR_PROVIDER = anthropic|openai|local.
TUTOR_PROVIDER=

# Anthropic / Claude (https://console.anthropic.com/settings/keys) — preferred
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6

# OpenAI (https://platform.openai.com/api-keys)
# IMPORTANT: set a monthly spend cap in the OpenAI dashboard before going live.
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o

# Reply length cap (tokens). Lower = cheaper/faster.
TUTOR_MAX_TOKENS=500

# ── Tutor rate limiting (Upstash Redis) ──────────────────────
# https://console.upstash.com → create a Redis DB → REST API section.
# Without these, limiting falls back to in-memory (fine for dev, weak on serverless).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Optional limit overrides (defaults: 8 req / 10s burst, 40 req / IP / day).
TUTOR_BURST_LIMIT=8
TUTOR_BURST_WINDOW_S=10
TUTOR_DAILY_IP_LIMIT=40

# Stripe (https://dashboard.stripe.com/apikeys) — billing is scaffolded, not active
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_PLUS_MONTHLY=

# Public site URL (used for auth redirects + Stripe return URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Study-reminder emails (optional) ─────────────────────────
# Resend (https://resend.com/api-keys). Without a key the notification cron
# runs in dry-run mode: it reports what it *would* send and sends nothing.
RESEND_API_KEY=
# Verified sender, e.g. "K53 Mentor <coach@yourdomain.co.za>".
NOTIFY_FROM_EMAIL=
# Shared secret for /api/cron/notifications (Vercel sends it automatically as
# "Authorization: Bearer <CRON_SECRET>" when this env var is set).
CRON_SECRET=

# Coach copy (plan rationale + session recaps) daily per-IP limit.
# (Outer abuse guard — per-user plan allowances are enforced separately.)
COACH_DAILY_IP_LIMIT=80

# Sign-scanner / tutor-photo vision calls per IP per day (priciest AI calls).
# (Outer abuse guard — vision is additionally paid-tier only, per user.)
VISION_DAILY_IP_LIMIT=20
